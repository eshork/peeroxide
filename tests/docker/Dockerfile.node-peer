FROM node:20-bookworm-slim

RUN apt-get update && apt-get install -y \
    iptables \
    iproute2 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY peeroxide/tests/node/package.json peeroxide/tests/node/package-lock.json* ./
RUN npm install

COPY peeroxide/tests/node/ ./
COPY peeroxide/tests/docker/scripts/ ./scripts/

ENTRYPOINT ["/bin/bash"]
